# Gemini API key — only needed if ADK_PROVIDER is "google" (default).
# Not required when using ADK_PROVIDER=openai-compatible.
GEMINI_API_KEY=your_gemini_api_key_here

# Amadeus API credentials (for Phase 2+ — flight/hotel search)
# Leave empty to use mock data during development
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# --- Main ADK Agent (conversation AI) ---
# Set to "openai-compatible" to use OpenRouter / OpenAI-compatible API
# instead of Google Gemini for all agents.
# ADK_PROVIDER=google
#
# Model name (default varies by provider)
# ADK_MODEL=

# --- OpenAI / OpenRouter (for both main agent & judge) ---
# Used by ADK when model string matches gpt-*, o1-*, o3-* patterns.
# Also used by JUDGE_PROVIDER=openai / openai-compatible as fallback.
OPENAI_API_KEY=sk-or-v1-put_your_openrouter_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- LLM Judge (prompt injection detection) ---
# When using OpenRouter, set JUDGE_PROVIDER=openai-compatible
# and the judge uses OPENAI_API_KEY / OPENAI_BASE_URL above.
JUDGE_PROVIDER=openai-compatible
JUDGE_MODEL=gpt-oss-120b
# JUDGE_API_KEY=  # overrides OPENAI_API_KEY for judge only
# JUDGE_API_BASE=  # overrides OPENAI_BASE_URL for judge only
